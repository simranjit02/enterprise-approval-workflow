{
  "name": "enterprise-approval-workflow",
  "version": "1.0.0",
  "description": "Enterprise Approval Workflow built with SAP CAP, XSUAA and SAP Build Process Automation.",
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-approval-ui": "cds watch --open approvalui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy enterprise-approval-workflow --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "test@company.com": {
            "password": "test",
            "roles": [
              "Requester",
              "Manager",
              "Finance",
              "Admin"
            ]
          },
          "manager@company.com": {
            "password": "manager",
            "roles": [
              "Manager"
            ]
          },
          "finance@company.com": {
            "password": "finance",
            "roles": [
              "Finance"
            ]
          },
          "requester@company.com": {
            "password": "requester",
            "roles": [
              "Requester"
            ]
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/approval-ui"
  ]
}
