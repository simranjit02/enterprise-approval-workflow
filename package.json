{
  "name": "enterprise-approval-workflow",
  "version": "1.0.0",
  "description": "Enterprise Approval Workflow built with SAP CAP, XSUAA and SAP Build Process Automation.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-approval-ui": "cds watch --open approvalui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "test@company.com": {
            "password": "test",
            "roles": [
              "Requester",
              "Manager",
              "Finance",
              "Admin"
            ]
          },
          "manager@company.com": {
            "password": "manager",
            "roles": [
              "Manager"
            ]
          },
          "finance@company.com": {
            "password": "finance",
            "roles": [
              "Finance"
            ]
          },
          "requester@company.com": {
            "password": "requester",
            "roles": [
              "Requester"
            ]
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        },
        "db": "hana"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/approval-ui"
  ]
}
