{
  "name": "enterprise-approval-workflow",
  "version": "1.0.0",
  "description": "Enterprise Approval Workflow built with SAP CAP, XSUAA and SAP Build Process Automation.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-approval-ui": "cds watch --open approvalui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "test@company.com": {
            "password": "test",
            "roles": [
              "Requester",
              "Manager",
              "Finance",
              "Admin"
            ]
          },
          "manager@company.com": {
            "password": "manager",
            "roles": [
              "Manager"
            ]
          },
          "finance@company.com": {
            "password": "finance",
            "roles": [
              "Finance"
            ]
          },
          "requester@company.com": {
            "password": "requester",
            "roles": [
              "Requester"
            ]
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        },
        "db": "hana"
      },
      "S4HANA_SANDBOX": {
        "kind": "odata-v2",
        "model": "srv/external/S4HANA_SANDBOX",
        "credentials": {
          "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_BUSINESS_PARTNER",
          "headers": {
            "APIKey": "${API_KEY}"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "S4HANA_SANDBOX",
            "path": "/s4hanacloud/sap/opu/odata/sap/API_BUSINESS_PARTNER"
          }
        },
        "csrf": true,
        "csrfInBatch": true
      },
      "API_PRODUCT_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_PRODUCT_SRV",
        "credentials": {
          "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_PRODUCT_SRV",
          "headers": {
            "APIKey": "${API_KEY}"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "API_PRODUCT_SRV",
            "path": "/s4hanacloud/sap/opu/odata/sap/API_PRODUCT_SRV"
          }
        },
        "csrf": true,
        "csrfInBatch": true
      },
      "API_COSTCENTER_SRV": {
        "kind": "odata",
        "model": "srv/external/API_COSTCENTER_SRV",
        "credentials": {
          "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata4/sap/api_cost_center/srvd_a2x/sap/costcenter/0001",
          "headers": {
            "APIKey": "${API_KEY}"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "API_COSTCENTER_SRV",
            "path": "/s4hanacloud/sap/opu/odata4/sap/api_cost_center/srvd_a2x/sap/costcenter/0001"
          }
        },
        "csrf": true,
        "csrfInBatch": true
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/approval-ui"
  ]
}